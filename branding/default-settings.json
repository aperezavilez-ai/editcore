{
  "security.workspace.trust.enabled": false,
  "security.workspace.trust.startupPrompt": "never",
  "security.workspace.trust.banner": "never",
  "security.workspace.trust.untrustedFiles": "open",
  "workbench.browser.showInTitleBar": 1,
  "workbench.browser.openLocalhostLinks": true,
  "workbench.secondarySideBar.defaultVisibility": "visible",
  "workbench.welcomePage.experimentalOnboarding": false,
  "chat.titleBar.signIn.enabled": false,
  "chat.agentHost.enabled": false,
  "chat.agents.copilotCli.hideExtensionHost": true,
  "chat.editor.copilotCli.hideExtensionHost": true,
  "chat.editor.localAgent.enabled": true,
  "chat.editor.defaultProvider": "local",
  "chat.agent.enabled": true,
  "chat.agentsControl.enabled": "compact",
  "chat.unifiedAgentsBar.enabled": false,
  "chat.newSession.defaultMode": "agent",
  "chat.customizations.harnessSelector.enabled": true,
  "chat.extensionTools.enabled": true,
  "chat.generalPurposeAgent.enabled": false,
  "chat.tips.enabled": false,
  "chat.disableAIFeatures": false,
  "telemetry.feedback.enabled": false,
  "github.gitAuthentication": true,
  "github.gitProtocol": "https",
  "git.openAfterClone": "whenNoFolderOpen",
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "terminal.integrated.initialHint": false,
  "terminal.integrated.initialHintCopilotCli": false
}
