{
  "name": "editcore-claude",
  "displayName": "EditCore - Claude Assistant",
  "description": "Chat con Claude (Anthropic) y OpenAI integrado nativamente en EditCore IDE.",
  "version": "1.4.0",
  "publisher": "editcore",
  "engines": {
    "vscode": "^1.85.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": true
  },
  "extensionKind": [
    "ui"
  ],
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "enabledApiProposals": [
    "defaultChatParticipant",
    "chatParticipantAdditions",
    "chatParticipantPrivate",
    "chatProvider",
    "chatContextProvider",
    "chatReferenceBinaryData"
  ],
  "activationEvents": [
    "onStartupFinished",
    "*",
    "onLanguageModelChatProvider:editcore",
    "onChatParticipant:editcore.claude",
    "onView:editcore.homeView",
    "onView:editcore.knowledgeView",
    "onView:editcore.marketplaceView",
    "onView:editcore.aiHubView",
    "onView:editcore.accountView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "editcore.claude",
        "name": "claude",
        "fullName": "Asistente",
        "description": "Asistente de codigo de EditCore (Anthropic y OpenAI)",
        "isDefault": true,
        "modes": [
          "ask",
          "agent"
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "editcore-sidebar",
          "title": "EditCore",
          "icon": "media/editcore-activity.svg"
        }
      ]
    },
    "views": {
      "editcore-sidebar": [
        {
          "type": "webview",
          "id": "editcore.homeView",
          "name": "Inicio"
        },
        {
          "type": "webview",
          "id": "editcore.accountView",
          "name": "Cuenta & API"
        },
        {
          "type": "webview",
          "id": "editcore.knowledgeView",
          "name": "Knowledge Center"
        },
        {
          "type": "webview",
          "id": "editcore.aiHubView",
          "name": "AI Hub"
        },
        {
          "type": "webview",
          "id": "editcore.marketplaceView",
          "name": "Marketplace"
        }
      ]
    },
