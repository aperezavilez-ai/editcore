    "menus": {
      "menubar/help": [
        {
          "command": "editcore.openAccountPanel",
          "group": "9_editcore@1"
        },
        {
          "command": "editcore.reloadWindow",
          "group": "9_editcore@2"
        }
      ],
      "view/title": [
        {
          "command": "editcore.reloadWindow",
          "when": "view =~ /^editcore\\./",
          "group": "navigation@0"
        }
      ],
      "editor/context": [
        {
          "command": "editcore.explainSelection",
          "when": "editorHasSelection",
          "group": "editcore@1"
        },
        {
          "command": "editcore.fixSelection",
          "when": "editorHasSelection",
          "group": "editcore@2"
        }
      ]
    },
    "configuration": {
      "title": "EditCore Claude",
      "properties": {
        "editcore.model": {
          "type": "string",
          "enum": [
            "claude-sonnet-4-6",
            "claude-opus-4-6",
            "claude-haiku-4-5"
          ],
          "enumDescriptions": [
            "Claude Sonnet 4.6 — equilibrado (recomendado)",
            "Claude Opus 4.6 — mas potente",
            "Claude Haiku 4.5 — rapido y economico"
          ],
          "default": "claude-sonnet-4-6",
          "description": "Modelo Claude (Anthropic) usado por chat, agente y @claude"
        },
        "editcore.openai.model": {
          "type": "string",
          "enum": [
            "gpt-4o",
            "gpt-4o-mini",
            "gpt-4.1",
            "gpt-4.1-mini"
          ],
          "enumDescriptions": [
            "GPT-4o — OpenAI por defecto",
            "GPT-4o mini — ligero y economico",
            "GPT-4.1 — mas reciente",
            "GPT-4.1 mini — compacto"
          ],
          "default": "gpt-4o",
          "description": "Modelo OpenAI usado como respaldo o proveedor principal"
        },
        "editcore.fallback.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Si Claude falla y hay key OpenAI, cambiar automaticamente a OpenAI"
        },
        "editcore.maxTokens": {
          "type": "number",
          "default": 16384,
          "minimum": 256,
          "maximum": 128000,
          "description": "Maximo de tokens por respuesta (chat y agente). Claude soporta hasta 64k salida."
        },
        "editcore.agent.alwaysWhenWorkspaceOpen": {
          "type": "boolean",
          "default": true,
          "description": "Con carpeta abierta, usar agente con herramientas reales aunque el modo no llegue del chat"
        },
        "editcore.agent.style": {
          "type": "string",
          "enum": [
            "cursor",
            "verbose"
          ],
          "enumDescriptions": [
            "Conciso: actua sin narrar; herramientas ocultas en el chat (recomendado)",
            "Detallado: muestra cada herramienta y fases del orquestador"
          ],
          "default": "cursor",
          "description": "Estilo de comunicacion del agente en modo Agent"
        },
        "editcore.orchestrator.enabled": {
          "type": "boolean",
          "default": false,
          "description": "En modo Agent: plan y aprobacion antes de ejecutar (desactivado = directo como Cursor)"
        },
        "editcore.plan.requireApproval": {
          "type": "boolean",
          "default": true,
          "description": "Pedir aprobación del plan antes de ejecutar en modo Agent"
        },
        "editcore.validation.afterAgent": {
          "type": "boolean",
          "default": true,
          "description": "Tras el agente, ejecutar build/test automáticamente"
        },
        "editcore.validation.commands": {
          "type": "array",
          "default": [],
          "description": "Comandos custom de validación (vacío = detectar npm run build/test)",
          "items": {
            "type": "string"
          }
        },
        "editcore.multiAgent.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Pipeline multiagente: Arquitecto -> Programador -> QA -> DevOps"
        },
        "editcore.router.autoSelect": {
          "type": "boolean",
          "default": false,
          "description": "Selección automática de proveedor/modelo según tipo de tarea (chat ask)"
        },
        "editcore.ollama.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Habilitar Ollama como proveedor local"
        },
        "editcore.ollama.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "URL base de Ollama"
        },
        "editcore.openrouter.model": {
          "type": "string",
          "default": "deepseek/deepseek-chat",
          "description": "Modelo por defecto en OpenRouter"
        },
        "editcore.plan": {
          "type": "string",
          "enum": [
            "free",
            "pro",
            "team",
            "business",
            "enterprise"
          ],
          "default": "enterprise",
          "description": "Plan EditCore (controla items del marketplace local)"
        },
        "editcore.product.checkUpdatesOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Comprobar nuevas versiones de EditCore al iniciar (cada 12 h)"
        },
        "editcore.marketplace.remoteUrl": {
          "type": "string",
          "default": "",
          "description": "URL opcional de catalogo JSON remoto (se fusiona con el bundled)"
        },
        "editcore.ecosystem.security.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Habilitar control de permisos por rol de equipo (org.json)"
        },
        "editcore.rag.useEmbeddings": {
          "type": "boolean",
          "default": true,
          "description": "Si hay Voyage API Key, re-rankear RAG con embeddings reales"
        },
        "editcore.rag.embeddingModel": {
          "type": "string",
          "default": "voyage-3-lite",
          "enum": [
            "voyage-3-lite",
            "voyage-3",
            "voyage-code-3"
          ],
          "description": "Modelo Voyage para embeddings de codigo"
        },
        "editcore.sessions.autoSummary": {
          "type": "boolean",
          "default": true,
          "description": "Tras cada sesion Agent, generar resumen con Claude (async)"
        },
        "editcore.diagnostics.useClaude": {
          "type": "boolean",
          "default": true,
          "description": "En autodiagnostico completo, analizar resultados con Claude"
        },
        "editcore.diagnostics.model": {
          "type": "string",
          "default": "claude-sonnet-4-6",
          "enum": [
            "claude-sonnet-4-6",
            "claude-opus-4-6",
            "claude-haiku-4-5"
          ],
          "description": "Modelo Claude para analisis de autodiagnostico"
        },
        "editcore.diagnostics.maxTokens": {
          "type": "number",
          "default": 2048,
          "minimum": 256,
          "maximum": 8192,
          "description": "Tokens maximos del analisis de autodiagnostico"
        },
        "editcore.intelligence.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Activa EditCore System Intelligence Layer (lectura y diagnóstico real del IDE)"
        },
        "editcore.intelligence.permissionLevel": {
          "type": "string",
          "enum": [
            "read",
            "write_docs",
            "write_config",
            "write_code"
          ],
          "default": "write_docs",
          "description": "Nivel maximo de permiso SIL sin aprobacion explicita"
        },
        "editcore.intelligence.autoGenerateMap": {
